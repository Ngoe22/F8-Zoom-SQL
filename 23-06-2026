-- Câu 2.1
select Students.full_name , Students.class , Students.gender from Scores
INNER JOIN Students on  Scores.student_id = Students.student_id
INNER JOIN Subjects on  Scores.subject_id = Subjects.subject_id
where Scores.score > 5 and ( Students.class = 'CNTT01' or Students.class = 'CNTT02' ) and Students.gender = 'F'
group by Scores.student_id

-- Câu 2.2
select Scores.subject_id , Subjects.subject_name , AVG(Scores.score) , count( Scores.student_id )  from Scores
INNER JOIN Students on  Scores.student_id = Students.student_id
INNER JOIN Subjects on  Scores.subject_id = Subjects.subject_id
group by Scores.subject_id
Having AVG(Scores.score) < 6.5 and  count( Scores.student_id ) >= 10

-- Câu 2.3
select Students.student_id , Students.full_name , Subjects.subject_name , Scores.score  from Scores
INNER JOIN Students on  Scores.student_id = Students.student_id
INNER JOIN Subjects on  Scores.subject_id = Subjects.subject_id
where Scores.score >= 8
limit 5 offset 10

