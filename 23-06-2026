-- Câu 3.1
select Categories.cat_id , Categories.cat_name ,
	sum( Sales.quantity * Products.price )
    from Sales
inner join Products on Sales.product_id = Products.product_id
inner join Employees on Sales.emp_id = Employees.emp_id
inner join Categories on Products.cat_id = Categories.cat_id
group by Categories.cat_id
having sum(Sales.quantity * Products.price) > 50000000;

-- Câu 3.2
select Employees.emp_name  , COUNT(DISTINCT Categories.cat_name)
    from Sales
inner join Products on Sales.product_id = Products.product_id
inner join Employees on Sales.emp_id = Employees.emp_id
inner join Categories on Products.cat_id = Categories.cat_id
where Employees.department = 'Sales'
group by Employees.emp_id
HAVING COUNT(DISTINCT Products.product_name) >= 3;

-- Câu 3.3
select  Products.product_name , sum(Sales.quantity)
    from Sales
inner join Products on Sales.product_id = Products.product_id
inner join Employees on Sales.emp_id = Employees.emp_id
inner join Categories on Products.cat_id = Categories.cat_id
group by Products.product_name
order by sum(Sales.quantity) desc
limit 3